# このファイルをコピーして .env を作る。.env はコミットしない。
#   cp .env.example .env
# src/config.ts が起動時に検証し、不正なら起動を中止する（fail fast）。

# --- 必須 ---
DATABASE_URL="postgresql://user:password@localhost:5432/mimamori-server"
PORT=9021

# JWT署名鍵。32文字以上。
# ローテーションすると全トークンが失効し、全クライアント端末の再ペアリングが必要になる。
#   生成例: openssl rand -base64 48
JWT_SECRET=

# --- 実行環境 ---
NODE_ENV=development
HOST=0.0.0.0

# --- トークン有効期限 ---
# JWT_ACCESS_TTL=1h
# JWT_REFRESH_TTL=30d
# 端末トークンは実質無期限。再ペアリングを求めると見守りが途切れるため。
# JWT_DEVICE_TTL=3650d

# --- 判定エンジンのパラメータ（誤報率を見ながら再デプロイなしで調整可能） ---
# DEFAULT_THRESHOLD_MINUTES=900     # コールドスタート時の閾値（15h）
# FREQUENT_THRESHOLD_MINUTES=600    # 「よく触る」自己申告時（10h）
# MIN_THRESHOLD_MINUTES=360         # 学習値の下限（6h。暴走防止）
# MAX_THRESHOLD_MINUTES=1440        # 学習値の上限（24h）
# THRESHOLD_MARGIN_MINUTES=120      # p99 に加算するマージン
# MIN_SAMPLE_COUNT=20               # 学習に必要な最小サンプル数
# LEARNING_WINDOW_WEEKS=8           # 学習windowの長さ
# COLD_START_DAYS=14                # この期間はデフォルト閾値を使う
# CONFIRMING_TIMEOUT_MINUTES=30     # CONFIRMING から ALERT へ遷移するまで
# ALERT_RENOTIFY_HOURS=24           # ALERT の再通知間隔
# NO_APP_GRACE_MINUTES=60           # アプリ未導入時の猶予
# WEAK_SIGNAL_FRESH_MINUTES=90      # 弱シグナルを「新しい」とみなす範囲

# クロス判定の ALERT 保留の上限。必ず上限を置くこと。
# 弱シグナル（冷蔵庫の稼働等）は本人が倒れていても出続けるため、
# 無制限にすると発報しなくなる。
# CROSS_CHECK_HOLD_MINUTES=180

# 判定ジョブがこの時間停止したら /healthz が503を返す。
# HEALTH_JOB_STALL_MINUTES=10

# 位置情報の保持日数。超過分は物理削除する。
# SOS_PURGE_DAYS=30

# --- 外部サービス（未設定なら該当機能は無効化される） ---
# 未設定だと通知が一切飛ばない（no-opドライバ）。本番では必須。
# FIREBASE_CREDENTIALS_PATH=/path/to/serviceAccount.json

# 各 webhook は secret 未設定だと503を返す（誰でも叩ける状態は作らない）。
# REVENUECAT_WEBHOOK_SECRET=
# SWITCHBOT_WEBHOOK_SECRET=
# POWER_METER_WEBHOOK_SECRET=

# ownerプランのSMS。3つ揃っていないと起動しない
# （中途半端な設定で「送れたつもり」になるのを防ぐため、全部設定か全部未設定のみ許可）。
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
